#!/usr/bin/env bash
# wf-engine — standalone dynamic-workflow runner (no cc-wasm runtime).
#
# Runs the same workflow .js scripts as cc-wasm's Workflow tool by talking to
# the Anthropic API directly, reusing your existing OAuth login. See README.md.
#
# Usage: wf-engine --project DIR (--script F | --name N | --inline 'JS') [opts]
#        wf-engine --help
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENGINE="$HERE/wf-engine.mjs"

# Resolve @anthropic-ai/sdk. ESM `import` does NOT consult NODE_PATH for bare
# specifiers, so we hand the engine the SDK's ESM entry as an ABSOLUTE PATH via
# WF_SDK_PATH (it dynamic-imports it). Search order, first hit wins:
#   1. ./node_modules          — fully self-contained (after `npm install` here)
#   2. ../app/node_modules     — the cc-wasm install's SDK (sibling of this dir)
#   3. the monorepo node_modules (absolute fallback)
CANDIDATES=(
  "$HERE/node_modules"
  "$HERE/../app/node_modules"
  "/data2/code/Dyspel/cwd/monorepo/packages/cc-wasm/node_modules"
)
SDK_ENTRY=""
for nm in "${CANDIDATES[@]}"; do
  for f in "$nm/@anthropic-ai/sdk/index.mjs" "$nm/@anthropic-ai/sdk/index.js"; do
    [ -e "$f" ] && { SDK_ENTRY="$f"; break 2; }
  done
done
if [ -z "$SDK_ENTRY" ]; then
  echo "wf-engine: @anthropic-ai/sdk not found." >&2
  echo "  Run 'npm install' in $HERE to make this fully self-contained," >&2
  echo "  or ensure the cc-wasm install (../app/node_modules) is present." >&2
  exit 1
fi

export WF_SDK_PATH="$SDK_ENTRY"
export NODE_PATH="$(dirname "$(dirname "$SDK_ENTRY")")${NODE_PATH:+:$NODE_PATH}"
exec node "$ENGINE" "$@"
